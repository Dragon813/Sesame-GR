<?xml version="1.0" encoding="utf-8"?>
<!-- MIUIX Text Button Background (transparent with ripple/press feedback) -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/miuix_button_text_bg_pressed" />
            <corners android:radius="@dimen/miuix_button_corner_radius" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/miuix_button_text_bg" />
            <corners android:radius="@dimen/miuix_button_corner_radius" />
        </shape>
    </item>
</selector>
