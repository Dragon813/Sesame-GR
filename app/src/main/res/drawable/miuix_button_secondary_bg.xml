<?xml version="1.0" encoding="utf-8"?>
<!-- MIUIX Secondary Button Background -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="@color/miuix_button_secondary_bg_pressed" />
            <corners android:radius="@dimen/miuix_button_corner_radius" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape>
            <solid android:color="@color/miuix_disabled_secondary" />
            <corners android:radius="@dimen/miuix_button_corner_radius" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/miuix_button_secondary_bg" />
            <corners android:radius="@dimen/miuix_button_corner_radius" />
        </shape>
    </item>
</selector>
