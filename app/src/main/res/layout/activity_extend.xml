<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/miuix_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/miuix_spacing_16"
        android:paddingEnd="@dimen/miuix_spacing_16"
        android:paddingBottom="@dimen/miuix_spacing_16">

        <View android:layout_width="match_parent" android:layout_height="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="扩展功能"
            android:textSize="34sp"
            android:textColor="@color/miuix_on_background"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="操作"
            android:textSize="13sp"
            android:textColor="#FFA0A0A0"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="@dimen/miuix_spacing_16"
            android:paddingEnd="@dimen/miuix_spacing_16"
            android:paddingTop="@dimen/miuix_spacing_16"
            android:paddingBottom="@dimen/miuix_spacing_4" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/miuix_card_bg"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/miuix_spacing_12">

            <Button android:id="@+id/btn_get_watered_items"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="查询浇水列表" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/miuix_divider_line" android:layout_marginStart="@dimen/miuix_spacing_16" />
            <Button android:id="@+id/btn_get_watering_items"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="查询被浇水列表" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/miuix_divider_line" android:layout_marginStart="@dimen/miuix_spacing_16" />
            <Button android:id="@+id/btn_get_tree_items"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="查询树木列表" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/miuix_divider_line" android:layout_marginStart="@dimen/miuix_spacing_16" />
            <Button android:id="@+id/btn_get_newTree_items"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="查询新树种列表" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/miuix_divider_line" android:layout_marginStart="@dimen/miuix_spacing_16" />
            <Button android:id="@+id/btn_query_area_trees"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="查询区域树木" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/miuix_divider_line" android:layout_marginStart="@dimen/miuix_spacing_16" />
            <Button android:id="@+id/btn_get_unlock_treeItems"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="获取解锁树木" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/miuix_divider_line" android:layout_marginStart="@dimen/miuix_spacing_16" />
            <Button android:id="@+id/btn_fill_watered_friend_list"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="填充浇水好友列表" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="功能"
            android:textSize="13sp"
            android:textColor="#FFA0A0A0"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="@dimen/miuix_spacing_16"
            android:paddingEnd="@dimen/miuix_spacing_16"
            android:paddingTop="8dp"
            android:paddingBottom="@dimen/miuix_spacing_4" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/miuix_card_bg"
            android:orientation="vertical">

            <Button android:id="@+id/btn_clear_dish_image"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="清除光盘行动图片" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/miuix_divider_line" android:layout_marginStart="@dimen/miuix_spacing_16" />
            <Button android:id="@+id/btn_set_custom_walk_path_id_list"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="设置自定义路径ID" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/miuix_divider_line" android:layout_marginStart="@dimen/miuix_spacing_16" />
            <Button android:id="@+id/btn_set_custom_walk_path_id_queue"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="设置路径ID队列" />
            <View android:layout_width="match_parent" android:layout_height="0.5dp"
                android:background="@color/miuix_divider_line" android:layout_marginStart="@dimen/miuix_spacing_16" />
            <Button android:id="@+id/btn_developer_mode"
                style="@style/MiuixButton.Text"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:gravity="start|center_vertical"
                android:padding="@dimen/miuix_spacing_16"
                android:text="开发者模式" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
