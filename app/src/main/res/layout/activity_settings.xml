<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/miuix_background"
    android:paddingStart="@dimen/miuix_spacing_16"
    android:paddingEnd="@dimen/miuix_spacing_16"
    android:paddingBottom="@dimen/miuix_spacing_16">

    <View android:layout_width="match_parent" android:layout_height="24dp" />

    <!-- 大标题行 -->
    <LinearLayout
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginTop="48dp" android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="配置"
            android:textSize="34sp" android:textColor="@color/miuix_on_background"
            android:fontFamily="sans-serif-medium" />

        <ImageView android:id="@+id/btn_export_config"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_upload"
            android:tint="@color/miuix_on_background_variant"
            android:padding="5dp" />

        <ImageView android:id="@+id/btn_import_config"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_upload"
            android:rotation="180"
            android:tint="@color/miuix_on_background_variant"
            android:padding="5dp"
            android:layout_marginStart="4dp" />

        <ImageView android:id="@+id/btn_delete_config"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:src="@android:drawable/ic_menu_delete"
            android:tint="@color/miuix_on_background_variant"
            android:padding="5dp"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- 主体：左侧Tab + 右侧内容 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- 左侧 Tab 列表 -->
        <ScrollView
            android:layout_width="0dp" android:layout_weight="7"
            android:layout_height="match_parent"
            android:scrollbars="none">

            <LinearLayout android:id="@+id/tab_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/miuix_card_bg"
                android:paddingTop="4dp" android:paddingBottom="4dp" />
        </ScrollView>

        <!-- 右侧内容区 -->
        <ScrollView
            android:layout_width="0dp" android:layout_weight="16"
            android:layout_height="match_parent"
            android:layout_marginStart="@dimen/miuix_spacing_8">

            <LinearLayout android:id="@+id/content_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="@dimen/miuix_spacing_16" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>
